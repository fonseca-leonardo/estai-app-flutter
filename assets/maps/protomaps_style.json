{
  "version": 8,
  "name": "Protomaps Light",
  "sources": {
    "protomaps": { "type": "vector" }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#cdcdcd" }
    },
    {
      "id": "earth",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "earth",
      "paint": { "fill-color": "#e0dfdc" }
    },
    {
      "id": "landcover_glacier",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landcover",
      "filter": ["==", ["get", "kind"], "glacier"],
      "paint": { "fill-color": "#ffffff" }
    },
    {
      "id": "landcover_forest",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landcover",
      "filter": ["==", ["get", "kind"], "forest"],
      "paint": { "fill-color": "#c8d6b9" }
    },
    {
      "id": "landuse_park",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["==", ["get", "kind"], "park"],
      "paint": { "fill-color": "#cfe0bd" }
    },
    {
      "id": "landuse_urban",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["==", ["get", "kind"], "urban_area"],
      "paint": { "fill-color": "#e6e1d8" }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "water",
      "paint": { "fill-color": "#a8c8e0" }
    },
    {
      "id": "boundaries_country",
      "type": "line",
      "source": "protomaps",
      "source-layer": "boundaries",
      "filter": ["<=", ["get", "kind_detail"], 2],
      "paint": { "line-color": "#888888", "line-width": 0.8 }
    },
    {
      "id": "boundaries_state",
      "type": "line",
      "source": "protomaps",
      "source-layer": "boundaries",
      "filter": [">", ["get", "kind_detail"], 2],
      "paint": { "line-color": "#aaaaaa", "line-width": 0.4 }
    },
    {
      "id": "roads_highway",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["==", ["get", "kind"], "highway"],
      "paint": { "line-color": "#f6c66f", "line-width": 1.2 }
    },
    {
      "id": "roads_major",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["==", ["get", "kind"], "major_road"],
      "paint": { "line-color": "#f0e1aa", "line-width": 0.8 }
    },
    {
      "id": "places_country",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["==", ["get", "kind"], "country"],
      "minzoom": 1,
      "layout": {
        "text-field": ["get", "name"],
        "text-size": 12
      },
      "paint": {
        "text-color": "#444444",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "places_city",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["==", ["get", "kind"], "city"],
      "minzoom": 4,
      "layout": {
        "text-field": ["get", "name"],
        "text-size": 11
      },
      "paint": {
        "text-color": "#222222",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    }
  ]
}
